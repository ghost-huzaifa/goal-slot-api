PORT=4000
CORS_ORIGIN=http://localhost:3010
JWT_SECRET='SECRET'
JWT_EXPIRATION='EXPIRATION_TIME'
DATABASE_URL='DB_URL'
DIRECT_URL='POSTGRESS_URL'
SUPABASE_URL=http://localhost
SUPABASE_SERVICE_ROLE_KEY=dev-service-role-key
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_PRICE_ID=price_mock
STRIPE_WEBHOOK_SECRET=whsec_mock
APP_URL=backend-app-url
POSTHOG_API_KEY=phc_your_project_api_key_here
POSTHOG_HOST=https://us.i.posthog.com or your host

ONBOARDING_EMAIL=onboarding@your-domain.com
NOTIFICATION_EMAIL=notifications@your-domain.com

# Coach feature — AES-256-GCM master key for encrypting user BYOK keys at rest
# Generate with: openssl rand -base64 32
# PROD: must be a separate, securely-stored secret in Vercel env settings
BYOK_ENCRYPTION_KEY=

# Shared Gemini Flash fallback (optional).
# When set, users who have not added their own BYOK key can still chat
# with the Coach using this key, gated by a per-user daily message
# count (default 20, override with SHARED_COACH_DAILY_LIMIT). Get a
# free key at https://aistudio.google.com/apikey — no credit card.
# Leave empty to disable the shared fallback entirely (users will be
# required to add their own key before the Coach answers anything).
GOOGLE_AI_SHARED_API_KEY=
SHARED_COACH_DAILY_LIMIT=20

